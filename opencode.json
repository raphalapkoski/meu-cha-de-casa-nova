{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "angular-cli": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@angular/cli",
        "mcp"
      ],
      "enabled": true
    },
    "nx-mcp": {
      "type": "local",
      "command": [
        "npx",
        "nx-mcp@latest"
      ],
      "enabled": true
    },
    "spartan-ui": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@spartan-ng/mcp"
      ],
      "enabled": true
    }
  }
}